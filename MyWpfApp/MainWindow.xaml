<Window x:Class="WpfDemo_1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfDemo_1"
        mc:Ignorable="d"
        Title="Embedded software"
        Height="450"
        Width="800"
        Background="{StaticResource AppBackground}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>

       
        <Label Content="Welcome To The Biggest Super Embedded Application ;)"
               Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4"
               FontSize="14" FontWeight="Bold" Foreground="#FFE5E5E5"/>

        <Label Content="Wish you the best My Friend ;)"
               Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4"
               FontSize="14" FontWeight="Bold" Foreground="#FFE5E5E5"/>

        <Button Grid.Column="2" Grid.Row="4" Content="TDO"
                Background="#2F4F4F" FontWeight="Bold" Foreground="#FFE5E5E5"/>

        <Button Grid.Column="4" Grid.Row="4" Content="Calendar"
                Background="#2F4F4F" FontWeight="Bold" Foreground="#FFE5E5E5"/>

        <Button Grid.Column="2" Grid.Row="5" Content="Domain Variable"
                Background="#2F4F4F" FontWeight="Bold" Foreground="#FFE5E5E5"
                Click="VD"/>

        <Button Grid.Column="4" Grid.Row="5" Content="Serial Port"
                Background="#2F4F4F" FontWeight="Bold" Foreground="#FFE5E5E5"/>

        <Button Grid.Column="2" Grid.Row="6" Content="Arr CCR Calculations"
                Background="#2F4F4F" FontWeight="Bold" Foreground="#FFE5E5E5"
                Click="ArrccrCacule"/>

        <Button Grid.Column="4" Grid.Row="6" Content="Applicable Formulas"
                Background="#2F4F4F" FontWeight="Bold" Foreground="#FFE5E5E5"
                Click="AppFormula"/>

        <Button Grid.Column="2" Grid.Row="7" Content="Please Login !"
                Click="LoginData"
                FontWeight="Bold" Foreground="#FFE5E5E5" Background="DarkSlateGray"/>

        <Button Grid.Column="4" Grid.Row="7" Content="Archived (Pass Require)"
                Click="Button_Archived"
                Background="#2F4F4F" FontWeight="Bold" Foreground="#FFE5E5E5"/>

        
        <ContentControl x:Name="MainContent"
                        Grid.Row="0"
                        Grid.Column="0"
                        Grid.RowSpan="10"
                        Grid.ColumnSpan="7"/>
    </Grid>
</Window>