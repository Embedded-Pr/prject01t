<Window
    x:Class="WpfDemo_1.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfDemo_1"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Embedded software"
    Width="800"
    Height="450"
    Background="{StaticResource AppBackground}"
    SizeToContent="Manual"
    mc:Ignorable="d">

    <Grid x:Name="myGrid">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="50" />
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="50" />
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="50" />
            <ColumnDefinition Width="10" />



        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
        </Grid.RowDefinitions>

        <ContentControl Name="MainContent" />
        <Label
            Grid.Row="1"
            Grid.Column="1"
            Grid.ColumnSpan="3"
            Content="Welcome To The Biggest Super Embedded Application ;)"
            FontSize="14"
            FontWeight="Bold"
            Foreground="#FFE5E5E5" />
        <Label
            Grid.Row="2"
            Grid.Column="1"
            Grid.ColumnSpan="3"
            Content="Wish you the best My Fried ;)"
            FontSize="14"
            FontWeight="Bold"
            Foreground="#FFE5E5E5" />
        <Button
            Grid.Row="7"
            Grid.Column="2"
            Background="DarkSlateGray"
            Click="LoginData"
            Content="Please Login !"
            FontWeight="Bold"
            Foreground="#FFE5E5E5" />
        <Button
            Grid.Row="7"
            Grid.Column="4"
            Background="#2F4F4F"
            Click="Button_Archived"
            Content="Archived (Pass Require)"
            FontWeight="Bold"
            Foreground="#FFE5E5E5" />
        <Button
            Grid.Row="6"
            Grid.Column="2"
            Background="#2F4F4F"
            Content="Arr CCR Calculations"
            FontWeight="Bold"
            Foreground="#FFE5E5E5" />
        <Button
            Grid.Row="6"
            Grid.Column="4"
            Background="#2F4F4F"
            Content="Applicable Formuals"
            FontWeight="Bold"
            Foreground="#FFE5E5E5" />
        <Button
            Grid.Row="5"
            Grid.Column="2"
            Background="#2F4F4F"
            Click="VD"
            Content="Domain Variable"
            FontWeight="Bold"
            Foreground="#FFE5E5E5" />
        <Button
            Grid.Row="5"
            Grid.Column="4"
            Background="#2F4F4F"
            Content="Serial Port"
            FontWeight="Bold"
            Foreground="#FFE5E5E5" />
        <Button
            Grid.Row="4"
            Grid.Column="4"
            Background="#2F4F4F"
            Content="Calender"
            FontWeight="Bold"
            Foreground="#FFE5E5E5" />
        <Button
            Grid.Row="4"
            Grid.Column="2"
            Background="#2F4F4F"
            Content="TDO"
            FontWeight="Bold"
            Foreground="#FFE5E5E5" />
        <Frame
            x:Name="LoginFrame"
            Grid.RowSpan="10"
            Grid.ColumnSpan="7"
            Margin="0,0,-30,-14"
            NavigationUIVisibility="Hidden" />
           
    </Grid>
</Window>
